# Example environment variables for local configuration.
# Copy this file to .env and fill in your secrets locally.

# ESP-IDF environment
# ESP_IDF_PATH=/home/user/esp/esp-idf

# Serial port for flashing/debugging
# ESPPORT=/dev/ttyUSB0

# Wi-Fi credentials used by local test harness or future OTA logic
# WIFI_SSID=your_ssid
# WIFI_PASSWORD=your_password

# ESP-NOW peer configuration
# ESP_NOW_PEER_MAC=AA:BB:CC:DD:EE:FF

# GitHub or external API keys used during development scripts
# GITHUB_TOKEN=ghp_xxx
